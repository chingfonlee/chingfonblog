---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { DEFAULT_CATEGORY_LABEL, postCategoryLabelMap, postsPageText } from '../../constants/siteText';

export async function getStaticPaths() {
  const isPreview =
    process.env.SITE_ENV === 'deploy-preview' || process.env.SITE_ENV === 'branch-deploy';
  const entries = await getCollection('posts', ({ data }) => isPreview || !data.draft);

  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const categoryLabel = postCategoryLabelMap[entry.data.category] ?? DEFAULT_CATEGORY_LABEL;
const formatDate = (date: Date) => date.toISOString().slice(0, 10).replace(/-/g, '/');
---

<BaseLayout title={`${entry.data.title} | lee-chingfon`} description={entry.data.description}>
  <section class="article-shell fade-in-up delay-1">
    <header class="article-header">
      <div class="filter-wrap" style="justify-content: flex-start;">
        <a class="button button-ghost" href="/posts/">回到文章列表</a>
        <span class="tag">{categoryLabel}</span>
        {entry.data.tags.includes('featured') && <span class="tag tag-featured">{postsPageText.featuredTag}</span>}
      </div>
      <p class="entry-meta">
        {formatDate(entry.data.pubDate)}
        {entry.data.draft ? ' · draft' : ''}
      </p>
      <h1>{entry.data.title}</h1>
      <p class="hero-lead" style="margin-top: 0;">{entry.data.description}</p>
    </header>

    {
      entry.data.coverImage ? (
        <figure class="article-cover">
          <img src={entry.data.coverImage} alt={entry.data.coverImageAlt ?? ''} loading="lazy" />
          {entry.data.coverImageAlt ? <figcaption>{entry.data.coverImageAlt}</figcaption> : null}
        </figure>
      ) : null
    }

    <div class="prose">
      <Content />
    </div>
  </section>
</BaseLayout>
