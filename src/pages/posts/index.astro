---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  DEFAULT_CATEGORY_LABEL,
  DEFAULT_POST_COVER,
  DEFAULT_POST_COVER_ALT,
  postCategoryLabelMap,
  postCategoryOptions,
  postsPageText,
} from '../../constants/siteText';

const isPreview =
  import.meta.env.DEV ||
  process.env.SITE_ENV === 'deploy-preview' ||
  process.env.SITE_ENV === 'branch-deploy';

const posts = (await getCollection('posts', ({ data }) => isPreview || !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const validCategories = postCategoryOptions.map((category) => category.value);
const getCategoryLabel = (category: string) => postCategoryLabelMap[category] ?? DEFAULT_CATEGORY_LABEL;
const formatDate = (date: Date) => date.toISOString().slice(0, 10).replace(/-/g, '/');
---

<BaseLayout title={postsPageText.pageTitle} description={postsPageText.pageDescription}>
  <section class="hero-shell fade-in-up delay-1">
    <p class="hero-eyebrow">Archive</p>
    <h1 class="hero-title">{postsPageText.heroTitle}</h1>
    <p class="hero-lead">{postsPageText.heroSubtitle}</p>
    <div id="category-filters" class="filter-wrap" style="margin-top: 1.3rem; justify-content: flex-start;">
      <a class="category-link" data-category="all" href="/posts/">{postsPageText.filterAllLabel}</a>
      {
        postCategoryOptions.map((category) => (
          <a class="category-link" data-category={category.value} href={`/posts/?category=${category.value}`}>
            {category.label}
          </a>
        ))
      }
    </div>
  </section>

  <p id="filter-status" class="status-note">{postsPageText.filterStatusAll}</p>

  <section class="section-shell fade-in-up delay-2">
    {
      posts.length === 0 ? (
        <p class="empty-state">{postsPageText.emptyCategory}</p>
      ) : (
        <>
          <ul id="post-list" class="clean collection-grid">
            {posts.map((post) => {
              const coverImage = post.data.coverImage ?? DEFAULT_POST_COVER;
              const coverImageAlt = post.data.coverImageAlt ?? DEFAULT_POST_COVER_ALT;

              return (
                <li class="entry-card post-item" data-category={post.data.category}>
                  <div class="entry-media">
                    <img src={coverImage} alt={coverImageAlt} loading="lazy" />
                    <div class="entry-tags">
                      {post.data.tags.includes('featured') && <span class="tag tag-featured">{postsPageText.featuredTag}</span>}
                      <span class="category-tag">{getCategoryLabel(post.data.category)}</span>
                    </div>
                  </div>
                  <div class="entry-body">
                    <p class="entry-meta">
                      {formatDate(post.data.pubDate)}
                      {post.data.draft ? ' · draft' : ''}
                    </p>
                    <a class="entry-link" href={`/posts/${post.slug}/`}>
                      <h2 class="entry-title">{post.data.title}</h2>
                    </a>
                    <p class="entry-description">{post.data.description}</p>
                  </div>
                </li>
              );
            })}
          </ul>
          <p id="empty-message" class="empty-state" hidden>
            {postsPageText.emptyCategory}
          </p>
        </>
      )
    }
  </section>

  <script
    is:inline
    define:vars={{
      validCategories,
      categoryLabels: postCategoryLabelMap,
      filterStatusInvalidCategory: postsPageText.filterStatusInvalidCategory,
      filterStatusCategoryPrefix: postsPageText.filterStatusCategoryPrefix,
    }}
  >
    (() => {
      const params = new URLSearchParams(window.location.search);
      const rawCategory = params.get('category');
      const selectedCategory = rawCategory && validCategories.includes(rawCategory) ? rawCategory : 'all';
      const hasInvalidCategory = Boolean(rawCategory) && !validCategories.includes(rawCategory);

      const status = document.getElementById('filter-status');
      const emptyMessage = document.getElementById('empty-message');
      const items = Array.from(document.querySelectorAll('.post-item'));
      const links = Array.from(document.querySelectorAll('.category-link'));

      let visibleCount = 0;
      for (const item of items) {
        const itemCategory = item.getAttribute('data-category');
        const visible = selectedCategory === 'all' || itemCategory === selectedCategory;
        item.hidden = !visible;
        if (visible) visibleCount += 1;
      }

      for (const link of links) {
        const isActive = link.getAttribute('data-category') === selectedCategory;
        link.classList.toggle('is-active', isActive);
      }

      if (status) {
        if (hasInvalidCategory) {
          status.textContent = filterStatusInvalidCategory;
        } else if (selectedCategory === 'all') {
          status.textContent = '';
        } else {
          status.textContent = `${filterStatusCategoryPrefix}${categoryLabels[selectedCategory] ?? selectedCategory}`;
        }
      }

      if (emptyMessage) {
        emptyMessage.hidden = visibleCount !== 0;
      }
    })();
  </script>
</BaseLayout>
