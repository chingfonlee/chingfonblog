---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const isPreview =
  import.meta.env.DEV ||
  process.env.SITE_ENV === 'deploy-preview' ||
  process.env.SITE_ENV === 'branch-deploy';

const posts = (await getCollection('posts', ({ data }) => isPreview || !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="lee-chingfon | AI Friendly Blog"
  description="lee-chingfon 的極簡優雅內容網站，使用 Astro、Decap CMS 與 Netlify。"
>
  <section class="card stack">
    <p class="chip">BRAND GUIDELINES STYLE</p>
    <h1 class="hero-title">lee-chingfon</h1>
    <p class="muted">
      以極簡的秩序承載優雅細節，讓視覺在平靜中留下清晰而長久的感受。
    </p>
    <p class="muted">
      我專注於打造高質感品牌網站與內容系統，讓品牌在第一眼就傳達清楚、沈著與可信任。
    </p>
    <div class="btn-row">
      <a class="btn btn-primary" href="/posts/">看作品應用</a>
      <a class="btn btn-secondary" href="/admin/">聯絡與合作</a>
    </div>
    <p class="muted">
      Visibility mode:
      {isPreview ? 'preview/dev includes drafts' : 'production build excludes drafts'}.
    </p>
  </section>

  <section class="card stack" style="margin-top: 1rem;">
    <h2>Posts</h2>
    {
      posts.length === 0 ? (
        <p class="muted">No published posts are available in the current build mode.</p>
      ) : (
        <ul class="clean stack">
          {posts.map((post) => (
            <li class="card">
              <a class="post-link" href={`/posts/${post.slug}/`}>
                <strong>{post.data.title}</strong>
              </a>
              <div class="muted">{post.data.description}</div>
              <div class="muted">
                {post.data.pubDate.toISOString().slice(0, 10)}
                {post.data.draft ? ' · draft' : ''}
              </div>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
