---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const isPreview =
  import.meta.env.DEV ||
  process.env.SITE_ENV === 'deploy-preview' ||
  process.env.SITE_ENV === 'branch-deploy';

const categoryLabelMap: Record<string, string> = {
  'ai-practice': 'AI 幫了誰',
  'productivity-system': '東拼西湊的產品',
  'life-thinking': '思考不停',
};

const posts = (await getCollection('posts', ({ data }) => isPreview || !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const projects = (await getCollection('projects', ({ data }) => isPreview || !data.draft)).sort(
  (a, b) => {
    const aDate = a.data.pubDate ? a.data.pubDate.valueOf() : 0;
    const bDate = b.data.pubDate ? b.data.pubDate.valueOf() : 0;
    return bDate - aDate;
  }
).slice(0, 3);

const tools = (await getCollection('tools', ({ data }) => isPreview || !data.draft)).sort(
  (a, b) => {
    const aDate = a.data.pubDate ? a.data.pubDate.valueOf() : 0;
    const bDate = b.data.pubDate ? b.data.pubDate.valueOf() : 0;
    return bDate - aDate;
  }
).slice(0, 3);

const featuredPostsData = posts.filter((post) => post.data.tags.includes('featured'));
const featuredPosts = featuredPostsData.length > 0 ? featuredPostsData.slice(0, 3) : posts.slice(0, 3);

const getCategoryLabel = (category: string) => categoryLabelMap[category] ?? '人生思考';
const DEFAULT_POST_COVER =
  'https://res.cloudinary.com/dwobro2s5/image/upload/f_auto,q_auto,c_fill,ar_16:9,w_1600/sample';
const DEFAULT_POST_COVER_ALT = 'lee-chingfon 預設文章封面';
---

<BaseLayout
  title="lee-chingfon | AI 幫了誰"
  description="沒有走過不會知道路的盡頭比想像中的更加模糊。"
>
  <section class="page-header-center">
    <p class="chip">BRAND GUIDELINES STYLE</p>
    <h1 class="hero-title">lee-chingfon</h1>
    <p class="muted">沒有走過不會知道路的盡頭比想像中的更加模糊。</p>
    <div class="btn-row" style="margin-top: 1.5rem; justify-content: center;">
      <a class="btn btn-primary" href="/posts/">所有的文章</a>
      <a class="btn btn-secondary" href="/projects/">我做的東西</a>
      <a class="btn btn-secondary" href="/tools/">推薦工具</a>
    </div>
    <p class="status-note" style="margin-top: 1rem;">
      Visibility mode: {isPreview ? 'preview/dev includes drafts' : 'production build excludes drafts'}.
    </p>
  </section>

  <section class="stack" style="margin-top: 2rem;">
    <div class="page-header-center" style="margin-bottom: 2rem;">
      <h2 class="section-title">精選文章</h2>
      <div style="margin-top: 1rem;">
        <a class="btn btn-secondary" href="/posts/">查看全部主題</a>
      </div>
    </div>
    {
      featuredPosts.length === 0 ? (
        <p class="card empty-state">目前尚未有文章。</p>
      ) : (
        <ul class="clean grid-3">
          {featuredPosts.map((post) => {
            const coverImage = post.data.coverImage ?? DEFAULT_POST_COVER;
            const coverImageAlt = post.data.coverImageAlt ?? DEFAULT_POST_COVER_ALT;

            return (
              <li class="card card-hover stack post-item">
                <div class="post-cover">
                  <img src={coverImage} alt={coverImageAlt} loading="lazy" />
                  <div class="cover-tags">
                    {post.data.tags.includes('featured') && <span class="category-tag tag-featured">精選</span>}
                    <span class="category-tag">{getCategoryLabel(post.data.category)}</span>
                  </div>
                </div>
                <p class="meta-line" style="margin-top: 0.5rem;">
                  {post.data.pubDate.toISOString().slice(0, 10).replace(/-/g, '/')}
                  {post.data.draft ? ' · draft' : ''}
                </p>
                <a class="post-link" href={`/posts/${post.slug}/`}>
                  <strong>{post.data.title}</strong>
                </a>
                <p class="muted">{post.data.description}</p>
              </li>
            );
          })}
        </ul>
      )
    }
  </section>

  <section class="stack">
    <div class="section-head" style="display: flex; justify-content: space-between; align-items: center;">
      <h2 class="section-title">我做的東西</h2>
      <a class="btn btn-secondary" href="/projects/">全部專案</a>
    </div>
    {
      projects.length === 0 ? (
        <p class="card empty-state">目前還沒有公開的專案。</p>
      ) : (
        <ul class="clean grid-3">
          {projects.map((item) => (
            <li class="card card-hover stack">
              {item.data.pubDate && (
                <p class="meta-line">
                  {item.data.pubDate.toISOString().slice(0, 10)}
                  {item.data.draft ? ' · draft' : ''}
                </p>
              )}
              {item.data.link ? (
                <a class="post-link" href={item.data.link}>
                  <strong>{item.data.title}</strong>
                </a>
              ) : (
                <div class="post-link">
                  <strong>{item.data.title}</strong>
                </div>
              )}
              <p class="muted">{item.data.description}</p>
            </li>
          ))}
        </ul>
      )
    }
  </section>

  <section class="stack">
    <div class="section-head" style="display: flex; justify-content: space-between; align-items: center;">
      <h2 class="section-title">推薦工具</h2>
      <a class="btn btn-secondary" href="/tools/">全部工具</a>
    </div>
    {
      tools.length === 0 ? (
        <p class="card empty-state">目前還沒有推薦的工具。</p>
      ) : (
        <ul class="clean grid-3">
          {tools.map((item) => (
            <li class="card card-hover stack">
              {item.data.pubDate && (
                <p class="meta-line">
                  {item.data.pubDate.toISOString().slice(0, 10)}
                  {item.data.draft ? ' · draft' : ''}
                </p>
              )}
              {item.data.link ? (
                <a class="post-link" href={item.data.link}>
                  <strong>{item.data.title}</strong>
                </a>
              ) : (
                <div class="post-link">
                  <strong>{item.data.title}</strong>
                </div>
              )}
              <p class="muted">{item.data.description}</p>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
