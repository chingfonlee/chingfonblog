---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { toolsPageText } from '../../constants/siteText';

const isPreview =
  import.meta.env.DEV ||
  process.env.SITE_ENV === 'deploy-preview' ||
  process.env.SITE_ENV === 'branch-deploy';

const tools = (await getCollection('tools', ({ data }) => !data.hidden && (isPreview || !data.draft))).sort(
  (a, b) => {
    const aDate = a.data.pubDate ? a.data.pubDate.valueOf() : 0;
    const bDate = b.data.pubDate ? b.data.pubDate.valueOf() : 0;
    return bDate - aDate;
  }
);
---

<BaseLayout title={toolsPageText.pageTitle} description={toolsPageText.pageDescription}>
  <section class="page-header-center">
    <h1 class="hero-title">{toolsPageText.heroTitle}</h1>
    <p class="section-subtitle">{toolsPageText.heroSubtitle}</p>
  </section>

  <section class="stack">
    {
      tools.length === 0 ? (
        <p class="card empty-state">{toolsPageText.emptyTools}</p>
      ) : (
        <ul class="clean grid-3">
          {tools.map((item) => (
            <li class="card card-hover stack">
              {item.data.pubDate && (
                <p class="meta-line">
                  {item.data.pubDate.toISOString().slice(0, 10)}
                  {item.data.draft ? ' · draft' : ''}
                </p>
              )}
              {item.data.link ? (
                <a class="post-link" href={item.data.link}>
                  <strong>{item.data.title}</strong>
                </a>
              ) : (
                <div class="post-link">
                  <strong>{item.data.title}</strong>
                </div>
              )}
              <div class="muted">{item.data.description}</div>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
