---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { toolsPageText } from '../../constants/siteText';

const isPreview =
  import.meta.env.DEV ||
  process.env.SITE_ENV === 'deploy-preview' ||
  process.env.SITE_ENV === 'branch-deploy';

const tools = (await getCollection('tools', ({ data }) => !data.hidden && (isPreview || !data.draft))).sort(
  (a, b) => {
    const aDate = a.data.pubDate ? a.data.pubDate.valueOf() : 0;
    const bDate = b.data.pubDate ? b.data.pubDate.valueOf() : 0;
    return bDate - aDate;
  }
);

const linkAttrs = (url?: string) => {
  if (!url) return {};
  const external = /^https?:\/\//.test(url);
  return external ? { target: '_blank', rel: 'noreferrer noopener' } : {};
};
---

<BaseLayout title={toolsPageText.pageTitle} description={toolsPageText.pageDescription}>
  <section class="hero-shell fade-in-up delay-1">
    <p class="hero-eyebrow">Tool Stack</p>
    <h1 class="hero-title">{toolsPageText.heroTitle}</h1>
    <p class="hero-lead">{toolsPageText.heroSubtitle}</p>
  </section>

  <section class="section-shell fade-in-up delay-2">
    {
      tools.length === 0 ? (
        <p class="empty-state">{toolsPageText.emptyTools}</p>
      ) : (
        <ul class="clean collection-grid">
          {tools.map((item) => (
            <li class="entry-card">
              <div class="entry-body">
                {item.data.pubDate && (
                  <p class="entry-meta">
                    {item.data.pubDate.toISOString().slice(0, 10)}
                    {item.data.draft ? ' · draft' : ''}
                  </p>
                )}
                {item.data.link ? (
                  <a class="entry-link" href={item.data.link} {...linkAttrs(item.data.link)}>
                    <h2 class="entry-title">{item.data.title}</h2>
                  </a>
                ) : (
                  <h2 class="entry-title">{item.data.title}</h2>
                )}
                <p class="entry-description">{item.data.description}</p>
              </div>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
