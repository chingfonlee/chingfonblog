---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'lee-chingfon AI-friendly blog powered by Astro.' } = Astro.props;
const pathname = Astro.url.pathname;

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/posts/', label: 'Posts' },
  { href: '/projects/', label: 'Projects' },
  { href: '/tools/', label: 'Tools' },
] as const;

const isActive = (href: string) => (href === '/' ? pathname === '/' : pathname.startsWith(href));
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#e9e4dc" />
    <style is:global>
      :root {
        color-scheme: light;
        --bg: oklch(0.965 0.018 84);
        --paper: oklch(0.988 0.01 78);
        --paper-strong: oklch(0.955 0.014 80);
        --ink: oklch(0.31 0.031 54);
        --ink-soft: oklch(0.43 0.024 56);
        --edge: oklch(0.84 0.024 74);
        --brand: oklch(0.55 0.138 39);
        --brand-deep: oklch(0.47 0.115 37);
        --accent: oklch(0.55 0.058 228);
        --hero-glow: oklch(0.78 0.07 72);
        --shadow: 0 22px 54px -30px oklch(0.29 0.03 54 / 0.42);
        --shadow-soft: 0 14px 36px -24px oklch(0.29 0.03 54 / 0.34);
        --radius-xl: 28px;
        --radius-lg: 22px;
        --radius-md: 16px;
        --radius-sm: 10px;
      }

      * {
        box-sizing: border-box;
      }

      @font-face {
        font-family: 'SweiSpringTC';
        src: url('/assets/fonts/SweiSpringCJKtc-Regular.woff2') format('woff2');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: 'SweiSpringTC';
        src: url('/assets/fonts/SweiSpringCJKtc-SemiBold.woff2') format('woff2');
        font-weight: 600;
        font-style: normal;
        font-display: swap;
      }

      html,
      body {
        margin: 0;
        min-height: 100%;
      }

      body {
        font-family: 'SweiSpringTC', 'Noto Serif TC', 'PingFang TC', 'Microsoft JhengHei', serif;
        color: var(--ink);
        line-height: 1.75;
        background:
          radial-gradient(circle at 12% -4%, oklch(0.9 0.05 71 / 0.8), transparent 45%),
          radial-gradient(circle at 95% 8%, oklch(0.92 0.03 228 / 0.65), transparent 42%),
          linear-gradient(145deg, oklch(0.975 0.01 86) 0%, oklch(0.955 0.018 80) 100%);
        position: relative;
      }

      body::before,
      body::after {
        content: '';
        position: fixed;
        inset: 0;
        pointer-events: none;
      }

      body::before {
        z-index: -2;
        opacity: 0.42;
        background-image:
          linear-gradient(to right, oklch(0.5 0.02 70 / 0.05) 1px, transparent 1px),
          linear-gradient(to bottom, oklch(0.5 0.02 70 / 0.05) 1px, transparent 1px);
        background-size: 38px 38px;
      }

      body::after {
        z-index: -1;
        opacity: 0.2;
        background-image: radial-gradient(oklch(0.38 0.03 52 / 0.22) 0.55px, transparent 0.55px);
        background-size: 8px 8px;
      }

      a {
        color: inherit;
      }

      .site-shell {
        width: min(1180px, calc(100% - 2.4rem));
        margin-inline: auto;
        padding: clamp(1.1rem, 1.8vw, 2rem) 0 clamp(2.8rem, 4vw, 4.8rem);
      }

      .site-header {
        position: sticky;
        top: 1rem;
        z-index: 20;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.2rem;
        padding: 1rem 1.2rem;
        border: 1px solid oklch(0.84 0.018 76 / 0.9);
        border-radius: var(--radius-xl);
        background:
          linear-gradient(135deg, oklch(0.992 0.009 82 / 0.84), oklch(0.978 0.012 76 / 0.84));
        backdrop-filter: blur(8px);
        box-shadow: var(--shadow-soft);
      }

      .brand {
        display: grid;
        gap: 0.16rem;
        text-decoration: none;
      }

      .brand-kicker {
        margin: 0;
        font-size: 0.72rem;
        letter-spacing: 0.17em;
        color: var(--ink-soft);
        text-transform: uppercase;
      }

      .brand-name {
        margin: 0;
        font-size: clamp(1.3rem, 2vw, 1.9rem);
        letter-spacing: 0.02em;
      }

      .site-nav {
        display: flex;
        gap: 0.35rem;
        flex-wrap: wrap;
      }

      .nav-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        text-decoration: none;
        border: 1px solid transparent;
        color: var(--ink-soft);
        padding: 0.5rem 0.95rem;
        font-size: 0.95rem;
        transition:
          color 260ms ease,
          border-color 260ms ease,
          background-color 260ms ease,
          transform 260ms ease;
      }

      .nav-link:hover {
        color: var(--ink);
        border-color: oklch(0.82 0.022 72 / 0.95);
        background: oklch(0.985 0.006 80 / 0.85);
      }

      .nav-link.is-active {
        color: oklch(0.28 0.03 52);
        border-color: oklch(0.67 0.074 39 / 0.45);
        background: oklch(0.93 0.03 44 / 0.52);
      }

      .page-main {
        display: grid;
        gap: clamp(1.4rem, 2.1vw, 2.4rem);
        margin-top: clamp(1rem, 1.8vw, 1.8rem);
      }

      .hero-shell {
        position: relative;
        overflow: clip;
        border-radius: calc(var(--radius-xl) + 6px);
        border: 1px solid oklch(0.84 0.022 74);
        background:
          radial-gradient(circle at 84% 18%, oklch(0.83 0.084 72 / 0.6), transparent 46%),
          linear-gradient(135deg, oklch(0.985 0.01 82), oklch(0.944 0.016 78));
        box-shadow: var(--shadow);
        padding: clamp(1.5rem, 3.8vw, 3.3rem);
      }

      .hero-shell::after {
        content: '';
        position: absolute;
        top: -28%;
        right: -9%;
        width: 240px;
        aspect-ratio: 1;
        border-radius: 50%;
        background: radial-gradient(circle, var(--hero-glow), transparent 72%);
        opacity: 0.35;
        pointer-events: none;
      }

      .hero-eyebrow {
        margin: 0;
        color: var(--ink-soft);
        letter-spacing: 0.15em;
        font-size: 0.74rem;
        text-transform: uppercase;
      }

      .hero-title {
        margin: 0.35rem 0 0;
        max-width: 14ch;
        font-size: clamp(1.7rem, 4.4vw, 3.8rem);
        line-height: 0.95;
        letter-spacing: -0.012em;
        text-wrap: balance;
      }

      .hero-lead {
        margin: 1rem 0 0;
        max-width: 56ch;
        color: color-mix(in oklab, var(--ink) 78%, var(--ink-soft));
      }

      .hero-actions {
        margin-top: 1.35rem;
        display: flex;
        gap: 0.8rem;
        flex-wrap: wrap;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        border: 1px solid transparent;
        text-decoration: none;
        font-size: 0.94rem;
        padding: 0.62rem 1.08rem;
        transition:
          transform 280ms ease,
          border-color 280ms ease,
          background-color 280ms ease,
          color 280ms ease,
          box-shadow 280ms ease;
      }

      .button-primary {
        color: oklch(0.97 0.01 85);
        background: linear-gradient(145deg, var(--brand), var(--brand-deep));
        box-shadow: 0 13px 28px -18px oklch(0.44 0.13 38 / 0.6);
      }

      .button-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 15px 24px -16px oklch(0.42 0.13 38 / 0.65);
      }

      .button-ghost {
        color: var(--ink);
        border-color: oklch(0.77 0.026 71);
        background: oklch(0.986 0.009 80 / 0.9);
      }

      .button-ghost:hover {
        transform: translateY(-2px);
        border-color: oklch(0.62 0.064 39 / 0.55);
        background: oklch(0.956 0.026 48 / 0.38);
      }

      .section-shell {
        display: grid;
        gap: 1rem;
      }

      .section-head {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: end;
        flex-wrap: wrap;
      }

      .section-title {
        margin: 0;
        font-size: clamp(1.5rem, 2.5vw, 2.35rem);
        line-height: 1.06;
        letter-spacing: -0.01em;
      }

      .section-subtitle,
      .section-lead,
      .muted {
        color: var(--ink-soft);
      }

      .section-subtitle,
      .section-lead {
        margin: 0.35rem 0 0;
      }

      .page-header-center {
        text-align: center;
        display: grid;
        gap: 0.7rem;
        justify-items: center;
      }

      .status-note {
        margin: 0;
        color: var(--ink-soft);
        font-size: 0.92rem;
      }

      ul.clean {
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .collection-grid {
        display: grid;
        gap: clamp(1rem, 1.8vw, 1.35rem);
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .entry-card {
        display: grid;
        gap: 0.82rem;
        border-radius: var(--radius-lg);
        border: 1px solid var(--edge);
        background: color-mix(in oklab, var(--paper) 86%, white 14%);
        box-shadow: var(--shadow-soft);
        overflow: clip;
        transition:
          transform 320ms ease,
          border-color 320ms ease,
          box-shadow 320ms ease;
      }

      .entry-card:hover {
        transform: translateY(-4px);
        border-color: oklch(0.64 0.058 39 / 0.48);
        box-shadow: var(--shadow);
      }

      .entry-media {
        position: relative;
        aspect-ratio: 16 / 9;
        overflow: hidden;
        background: var(--paper-strong);
      }

      .entry-media img {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: cover;
      }

      .entry-body {
        display: grid;
        gap: 0.75rem;
        padding: 1.1rem 1.1rem 1.2rem;
      }

      .entry-meta {
        margin: 0;
        font-size: 0.84rem;
        color: var(--ink-soft);
        letter-spacing: 0.04em;
      }

      .entry-title {
        margin: 0;
        font-size: 1.22rem;
        line-height: 1.2;
      }

      .entry-link {
        text-decoration: none;
      }

      .entry-link:hover .entry-title {
        text-decoration: underline;
        text-underline-offset: 0.24em;
      }

      .entry-description {
        margin: 0;
        color: var(--ink-soft);
      }

      .entry-tags {
        position: absolute;
        left: 0.85rem;
        top: 0.85rem;
        display: flex;
        gap: 0.45rem;
        flex-wrap: wrap;
      }

      .tag,
      .category-tag,
      .category-link {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        border: 1px solid oklch(0.76 0.032 72 / 0.9);
        padding: 0.33rem 0.72rem;
        font-size: 0.76rem;
        line-height: 1;
        text-decoration: none;
        background: oklch(0.985 0.01 80 / 0.92);
        color: var(--ink-soft);
        backdrop-filter: blur(4px);
      }

      .tag-featured {
        border-color: transparent;
        color: oklch(0.97 0.01 80);
        background: linear-gradient(130deg, oklch(0.58 0.155 41), oklch(0.51 0.148 34));
      }

      .category-link {
        transition:
          color 260ms ease,
          border-color 260ms ease,
          background-color 260ms ease,
          transform 260ms ease;
      }

      .category-link:hover {
        color: var(--ink);
        border-color: oklch(0.63 0.062 39 / 0.45);
        background: oklch(0.952 0.026 50 / 0.48);
        transform: translateY(-1px);
      }

      .category-link.is-active {
        color: oklch(0.97 0.01 80);
        border-color: transparent;
        background: linear-gradient(140deg, var(--brand), var(--brand-deep));
      }

      .filter-wrap {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
        justify-content: center;
      }

      .empty-state {
        margin: 0;
        padding: 1rem 1.2rem;
        border: 1px dashed oklch(0.76 0.028 73);
        border-radius: var(--radius-md);
        color: var(--ink-soft);
        background: oklch(0.986 0.008 80 / 0.74);
      }

      .article-shell {
        border-radius: var(--radius-xl);
        border: 1px solid var(--edge);
        background: color-mix(in oklab, var(--paper) 92%, white 8%);
        box-shadow: var(--shadow);
        padding: clamp(1.2rem, 2.6vw, 2.2rem);
      }

      .article-header {
        display: grid;
        gap: 0.7rem;
        margin-bottom: 1rem;
      }

      .article-header h1 {
        margin: 0;
        font-size: clamp(1.8rem, 4.2vw, 3rem);
        line-height: 1.03;
        letter-spacing: -0.01em;
        text-wrap: balance;
      }

      .article-cover {
        margin: 1.15rem 0;
      }

      .article-cover img {
        width: 100%;
        border-radius: var(--radius-md);
        border: 1px solid var(--edge);
        display: block;
      }

      .article-cover figcaption {
        margin-top: 0.55rem;
        font-size: 0.9rem;
        color: var(--ink-soft);
      }

      .prose {
        line-height: 1.86;
        font-size: 1.02rem;
      }

      .prose h2,
      .prose h3,
      .prose h4 {
        line-height: 1.22;
        margin-top: 1.85rem;
        margin-bottom: 0.8rem;
      }

      .prose p,
      .prose li {
        color: color-mix(in oklab, var(--ink) 87%, var(--ink-soft));
      }

      .prose blockquote {
        margin: 1.1rem 0;
        padding: 0.18rem 0 0.18rem 1rem;
        border-left: 3px solid oklch(0.6 0.078 39 / 0.7);
        color: var(--ink-soft);
      }

      .prose a {
        color: var(--brand-deep);
      }

      .prose img {
        width: 100%;
        border-radius: var(--radius-md);
      }

      .fade-in-up {
        animation: fade-in-up 700ms cubic-bezier(0.19, 1, 0.22, 1) both;
      }

      .delay-1 {
        animation-delay: 110ms;
      }

      .delay-2 {
        animation-delay: 210ms;
      }

      .delay-3 {
        animation-delay: 310ms;
      }

      @keyframes fade-in-up {
        from {
          opacity: 0;
          transform: translateY(14px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @media (max-width: 980px) {
        .collection-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }

      @media (max-width: 760px) {
        .site-shell {
          width: min(1180px, calc(100% - 1.2rem));
        }

        .site-header {
          position: static;
          border-radius: var(--radius-lg);
          padding: 0.9rem 0.95rem;
        }

        .brand-name {
          font-size: 1.25rem;
        }

        .collection-grid {
          grid-template-columns: 1fr;
        }

        .hero-title {
          max-width: 11ch;
        }

        .section-head {
          align-items: start;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation: none !important;
          transition: none !important;
          scroll-behavior: auto !important;
        }
      }
    </style>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header fade-in-up">
        <a class="brand" href="/">
          <p class="brand-kicker">AI-Friendly Blog</p>
          <p class="brand-name">lee-chingfon</p>
        </a>
        <nav class="site-nav" aria-label="main navigation">
          {
            navItems.map((item) => (
              <a class:list={["nav-link", { 'is-active': isActive(item.href) }]} href={item.href}>
                {item.label}
              </a>
            ))
          }
        </nav>
      </header>
      <main class="page-main">
        <slot />
      </main>
    </div>
  </body>
</html>
